# OS
.DS_Store
Thumbs.db
desktop.ini

# Lean build artifacts
/lean-checker/build/
/lean-checker/.lake/
# Kernel-passing proofs the gateway drops here at runtime — episode-local artifacts,
# not source. Delete freely; they regenerate on the next certified solve.
/lean-checker/LeanChecker/Verified/*.lean
# Scaffold CI from the mathlib template — would run full Mathlib builds on GitHub.
# Deliberately untracked; restore from `lake new <name> math` if ever wanted.
/lean-checker/.github/

# Local MCP registration (machine-specific absolute paths)
.mcp.json

# Local DB snapshots and incidental tooling
*.bak
tunnel.zip
tunnel_client_dir/

# Environment files
.env
.env.local

# IGP24 local search/submission artifacts. Keep API keys and unpublished
# candidate batches out of git.
/igp24/
/data/igp24/
/data/equational-theories-lean-stage2/
# Upstream reference clone (embedded git repo, machine-local; fetch it yourself).
/data/equational_theories_upstream/

# Kilo workspace tooling (machine-local)
.kilo/
docs/playtests/exports/
formal-conjectures/
